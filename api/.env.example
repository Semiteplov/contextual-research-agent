# ── API server configuration ─────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_LOG_LEVEL=info
API_WORKERS=1
API_RELOAD=false

# Comma-separated API keys. Empty string = auth disabled (dev only).
API_KEYS=

# CORS — comma-separated allowed origins
API_CORS_ORIGINS=http://localhost:7860,http://localhost:3000

API_MAX_QUERY_LENGTH=2000
API_REQUEST_TIMEOUT=600.0

# ── Agent configuration ──────────────────────────────────────────────
AGENT_COLLECTION=peft_hybrid
AGENT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-0.6B
AGENT_RERANK=true
AGENT_RERANK_MODEL=BAAI/bge-reranker-v2-m3
AGENT_DEVICE=
AGENT_CHANNELS=dense,sparse,graph_entity,paper_level

AGENT_LLM_PROVIDER=ollama
AGENT_LLM_MODEL=qwen3:8b
AGENT_LLM_HOST=http://localhost:11434
AGENT_TEMPERATURE=0.1
AGENT_MAX_TOKENS=2048
